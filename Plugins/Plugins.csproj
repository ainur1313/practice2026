<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\CommandLib\CommandLib.csproj" />
	</ItemGroup>

	<Target Name="PostBuild" AfterTargets="Build">
		<!-- Создаём папку plugins (исправлено название) -->
		<MakeDir Directories="$(SolutionDir)PluginApp\bin\$(Configuration)\net10.0\plugins\"
				 Condition="!Exists('$(SolutionDir)PluginApp\bin\$(Configuration)\net10.0\plugins\')" />

		<!-- Копируем DLL в папку plugins -->
		<Copy SourceFiles="$(TargetDir)$(TargetName).dll"
			  DestinationFolder="$(SolutionDir)PluginApp\bin\$(Configuration)\net10.0\plugins\"
			  Condition="Exists('$(TargetDir)$(TargetName).dll')" />
	</Target>

</Project>
